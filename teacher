<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>스승의 날 롤링페이퍼 🎓</title>
<link href="https://fonts.googleapis.com/css2?family=Nanum+Myeongjo:wght@400;700&family=Noto+Sans+KR:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{
  --cream:#0f1729;--warm:#1a2540;--pk:#c9a84c;--pv:#1e3060;--pv2:#c9a84c;
  --text:#f0e6c8;--text2:#b8a882;--text3:#6e6448;
  --border:rgba(201,168,76,0.2);--shadow:rgba(201,168,76,0.1);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Noto Sans KR',sans-serif;background:#0d1526;color:var(--text);min-height:100vh;overflow-x:hidden;}

/* 꽃 배경 */
.flower-bg{position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden;}
.flower-bg svg{position:absolute;}

.page{position:relative;z-index:1;}
.loading{display:flex;align-items:center;justify-content:center;min-height:100vh;font-size:14px;color:var(--text3);}

/* 관리자 바 */
.admin-bar{background:linear-gradient(135deg,#7b3fa0,#c2649a);color:#fff;padding:12px 24px;display:flex;align-items:center;justify-content:space-between;font-size:13px;position:sticky;top:0;z-index:90;}
.admin-badge{background:rgba(255,255,255,0.25);color:#fff;font-size:10px;font-weight:700;padding:2px 7px;border-radius:10px;margin-right:8px;}
.admin-btns{display:flex;gap:8px;flex-wrap:wrap;}
.admin-btn{background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.25);border-radius:5px;color:#fff;cursor:pointer;font-family:'Noto Sans KR',sans-serif;font-size:12px;padding:6px 12px;}
.admin-btn:hover{background:rgba(255,255,255,0.25);}

/* 설정 패널 */
.settings-panel{background:#1a2540;border-bottom:1px solid var(--border);padding:20px 24px;display:none;}
.settings-panel.open{display:block;}
.settings-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;max-width:800px;}
.settings-group{display:flex;flex-direction:column;gap:6px;}
.settings-label{font-size:11px;color:var(--text2);font-weight:500;}
.settings-input{background:rgba(255,255,255,0.06);border:1px solid var(--border);border-radius:5px;color:var(--text);font-family:'Noto Sans KR',sans-serif;font-size:13px;padding:8px 10px;outline:none;width:100%;}
.settings-input:focus{border-color:var(--pv);}
.settings-save{margin-top:12px;background:linear-gradient(135deg,var(--pv),var(--pk));border:none;border-radius:5px;color:#fff;cursor:pointer;font-family:'Noto Sans KR',sans-serif;font-size:13px;font-weight:500;padding:8px 20px;}

/* 링크 박스 */
.link-box{background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:8px;padding:16px 20px;margin:16px 24px;}
.link-box-title{font-size:12px;color:var(--text2);margin-bottom:10px;font-weight:500;}
.link-row{display:flex;gap:8px;align-items:center;margin-bottom:8px;}
.link-row:last-child{margin-bottom:0;}
.link-label{font-size:11px;color:var(--text3);width:70px;flex-shrink:0;}
.link-url{flex:1;background:#fff;border:1px solid var(--border);border-radius:5px;color:var(--text2);font-size:11px;padding:6px 10px;font-family:monospace;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.link-copy{background:transparent;border:1px solid var(--border);border-radius:5px;color:var(--text2);cursor:pointer;font-size:11px;padding:6px 10px;white-space:nowrap;}
.link-copy:hover{background:var(--pv);border-color:var(--pv);color:#fff;}

/* 히어로 */
.hero{text-align:center;padding:70px 24px 40px;position:relative;}
.hero-flowers{display:flex;justify-content:center;gap:8px;margin-bottom:20px;font-size:22px;letter-spacing:4px;opacity:0.85;}
.photo-wrap{position:relative;width:180px;margin:0 auto 28px;}
.photo-ring{position:absolute;inset:-10px;border-radius:50%;border:1px dashed rgba(201,168,76,0.4);animation:spin 20s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
.photo-frame{width:180px;height:180px;border-radius:50%;border:3px solid #c9a84c;overflow:hidden;background:var(--warm);display:flex;align-items:center;justify-content:center;box-shadow:0 0 0 8px rgba(201,168,76,0.08),0 8px 36px rgba(201,168,76,0.15);position:relative;z-index:1;}
.photo-frame img{width:100%;height:100%;object-fit:cover;}
.photo-placeholder{display:flex;flex-direction:column;align-items:center;gap:6px;color:var(--text3);font-size:12px;}
.hero-name{font-family:'Nanum Myeongjo',serif;font-size:34px;font-weight:700;color:var(--pv);margin-bottom:10px;letter-spacing:0.04em;}
.hero-msg{font-size:15px;color:var(--text2);line-height:1.9;max-width:480px;margin:0 auto 14px;font-weight:300;}
.hero-date{font-size:12px;color:var(--text3);letter-spacing:0.12em;}
.divider{display:flex;align-items:center;justify-content:center;gap:10px;margin:28px auto;color:var(--pv2);font-size:14px;opacity:0.7;}
.divider::before,.divider::after{content:'';flex:1;max-width:80px;height:1px;background:linear-gradient(to right,transparent,var(--pv2));}
.divider::after{background:linear-gradient(to left,transparent,var(--pv2));}

/* 편지 그리드 */
.letters-section{padding:0 24px 100px;max-width:920px;margin:0 auto;}
.letters-title{text-align:center;font-family:'Nanum Myeongjo',serif;font-size:18px;color:var(--pv);margin-bottom:32px;letter-spacing:0.08em;}
.letters-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:18px;}

/* 봉투 */
.envelope-wrap{position:relative;}
.envelope{cursor:pointer;transition:transform 0.2s,box-shadow 0.2s;}
.envelope:hover{transform:translateY(-6px);filter:brightness(1.03);}
.envelope-body{background:linear-gradient(160deg,#1a2540,#0f1729);border:1px solid rgba(201,168,76,0.2);border-radius:12px 12px 0 0;padding:28px 16px 18px;text-align:center;box-shadow:0 6px 20px rgba(155,77,202,0.1);min-height:140px;position:relative;overflow:hidden;}
.envelope-corner{position:absolute;top:0;left:0;right:0;height:40px;overflow:hidden;}
.envelope-corner::before{content:'';position:absolute;top:-20px;left:50%;transform:translateX(-50%);width:120%;height:60px;background:rgba(201,168,76,0.08);clip-path:polygon(0 0,100% 0,50% 100%);}
.envelope-petals{position:absolute;top:6px;left:0;right:0;display:flex;justify-content:center;gap:3px;font-size:11px;}
.envelope-seal{width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,var(--pv),var(--pk));border:3px solid rgba(255,255,255,0.6);display:flex;align-items:center;justify-content:center;margin:4px auto 10px;font-size:17px;box-shadow:0 3px 10px rgba(155,77,202,0.3);}
.envelope-from{font-size:13px;font-weight:500;color:var(--pv);margin-bottom:4px;}
.envelope-locked{font-size:11px;color:var(--text3);margin-top:4px;}
.envelope-flap{width:100%;height:0;border-left:50% solid transparent;border-right:50% solid transparent;border-top:36px solid rgba(30,48,96,0.9);filter:drop-shadow(0 -1px 2px rgba(201,168,76,0.15));}
.delete-btn{position:absolute;top:8px;right:8px;background:rgba(200,50,50,0.08);border:1px solid rgba(200,50,50,0.2);border-radius:4px;color:#c06060;cursor:pointer;font-size:11px;padding:3px 7px;opacity:0;transition:opacity 0.15s;z-index:2;}
.envelope-wrap:hover .delete-btn{opacity:1;}

/* 빈 상태 */
.empty-letters{text-align:center;padding:60px 24px;color:var(--text3);grid-column:1/-1;}
.empty-letters p{font-size:14px;margin-top:8px;}

/* 모달 */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(5,10,20,0.75);z-index:100;align-items:center;justify-content:center;padding:24px;backdrop-filter:blur(4px);}
.modal-bg.open{display:flex;}
.modal{background:linear-gradient(160deg,#13203a,#0f1729);border-radius:20px;padding:40px 36px;max-width:480px;width:100%;position:relative;box-shadow:0 24px 64px rgba(100,30,160,0.18);border:1px solid rgba(192,132,224,0.25);max-height:80vh;overflow-y:auto;animation:modalIn 0.25s ease;}
@keyframes modalIn{from{opacity:0;transform:scale(0.95) translateY(10px);}to{opacity:1;transform:scale(1) translateY(0);}}
.modal-close{position:absolute;top:16px;right:20px;background:none;border:none;font-size:22px;cursor:pointer;color:var(--text3);}
.modal-close:hover{color:var(--text);}
.modal-flowers{text-align:center;font-size:20px;letter-spacing:6px;margin-bottom:8px;opacity:0.7;}
.modal-seal{width:52px;height:52px;border-radius:50%;background:linear-gradient(135deg,var(--pv),var(--pk));display:flex;align-items:center;justify-content:center;font-size:24px;margin:0 auto 12px;box-shadow:0 4px 16px rgba(155,77,202,0.3);border:3px solid rgba(255,255,255,0.5);}
.modal-from-label{text-align:center;font-size:12px;color:var(--text3);margin-bottom:2px;}
.modal-name{text-align:center;font-family:'Nanum Myeongjo',serif;font-size:22px;color:var(--pv);margin-bottom:16px;}
.modal-divider{display:flex;align-items:center;justify-content:center;gap:6px;margin:0 auto 20px;color:var(--pv2);font-size:12px;opacity:0.7;}
.modal-divider::before,.modal-divider::after{content:'';width:30px;height:1px;background:var(--pv2);}
.modal-body{font-size:14px;line-height:2.1;color:var(--text);white-space:pre-wrap;font-weight:300;}
.modal-date{text-align:right;font-size:11px;color:var(--text3);margin-top:20px;}

/* 쓰기 FAB */
.write-fab{position:fixed;bottom:32px;right:32px;background:linear-gradient(135deg,var(--pv),var(--pk));border:none;border-radius:50px;color:#fff;cursor:pointer;font-family:'Noto Sans KR',sans-serif;font-size:14px;font-weight:500;padding:14px 24px;box-shadow:0 4px 20px rgba(155,77,202,0.4);display:flex;align-items:center;gap:8px;transition:all 0.2s;z-index:50;}
.write-fab:hover{opacity:0.9;transform:translateY(-2px);}

/* 쓰기 모달 */
.write-modal{background:linear-gradient(160deg,#13203a,#0f1729);border-radius:20px;padding:36px;max-width:500px;width:100%;box-shadow:0 24px 64px rgba(100,30,160,0.18);border:1px solid rgba(192,132,224,0.25);animation:modalIn 0.25s ease;}
.write-modal h3{font-family:'Nanum Myeongjo',serif;font-size:20px;color:var(--pv);text-align:center;margin-bottom:24px;}
.form-group{margin-bottom:16px;}
.form-label{font-size:12px;color:var(--text2);margin-bottom:6px;display:block;}
.form-input,.form-textarea{width:100%;background:rgba(255,255,255,0.06);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:'Noto Sans KR',sans-serif;font-size:14px;padding:10px 12px;outline:none;transition:border-color 0.15s;}
.form-input:focus,.form-textarea:focus{border-color:var(--pv);}
.form-textarea{resize:vertical;min-height:140px;line-height:1.8;}
.emoji-row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px;}
.emoji-btn{background:rgba(255,255,255,0.06);border:1px solid var(--border);border-radius:20px;cursor:pointer;font-size:18px;padding:4px 10px;transition:all 0.1s;}
.emoji-btn:hover,.emoji-btn.selected{background:var(--pv);border-color:var(--pv);}
.form-btns{display:flex;gap:8px;margin-top:20px;}
.btn-submit{flex:1;background:linear-gradient(135deg,var(--pv),var(--pk));border:none;border-radius:8px;color:#fff;cursor:pointer;font-family:'Noto Sans KR',sans-serif;font-size:14px;font-weight:500;padding:12px;transition:all 0.15s;}
.btn-submit:hover{opacity:0.9;}
.btn-submit:disabled{opacity:0.6;cursor:not-allowed;}
.btn-cancel{background:transparent;border:1px solid var(--border);border-radius:8px;color:var(--text2);cursor:pointer;font-family:'Noto Sans KR',sans-serif;font-size:14px;padding:12px 20px;}

/* 토스트 */
.toast{position:fixed;bottom:100px;left:50%;transform:translateX(-50%) translateY(20px);background:linear-gradient(135deg,var(--pv),var(--pk));color:#fff;font-size:13px;padding:10px 20px;border-radius:20px;opacity:0;transition:all 0.3s;z-index:200;white-space:nowrap;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

@media(max-width:600px){
  .letters-grid{grid-template-columns:repeat(2,1fr);}
  .modal,.write-modal{padding:28px 20px;border-radius:16px;}
  .hero-name{font-size:28px;}
  .admin-btns{gap:4px;}
  .admin-btn{font-size:11px;padding:5px 8px;}
}
</style>
</head>
<body>

<div class="flower-bg">
  <!-- 카네이션 좌상단 -->
