</div>

<div id="app"><div class="loading">불러오는 중...</div></div>

<!-- 읽기 모달 -->
<div class="modal-bg" id="readModal" onclick="closeReadModal(event)">
  <div class="modal">
    <button class="modal-close" onclick="closeReadModal()">×</button>
    <div class="modal-flowers" id="modalFlowers">🌸 🌷 🌺</div>
    <div class="modal-seal" id="modalEmoji">💌</div>
    <div class="modal-from-label">From</div>
    <div class="modal-name" id="modalFrom"></div>
    <div class="modal-divider">🌸</div>
    <div class="modal-body" id="modalBody"></div>
    <div class="modal-date" id="modalDate"></div>
    <div id="myLetterBtns" style="display:none;margin-top:20px;display:none;gap:8px;flex-wrap:wrap;">
      <button onclick="openEditModal()" style="flex:1;background:transparent;border:1px solid var(--border);border-radius:6px;color:var(--text2);cursor:pointer;font-family:'Noto Sans KR',sans-serif;font-size:13px;padding:10px;">✏️ 수정</button>
      <button onclick="deleteMyLetter()" style="flex:1;background:transparent;border:1px solid rgba(200,50,50,0.3);border-radius:6px;color:#c06060;cursor:pointer;font-family:'Noto Sans KR',sans-serif;font-size:13px;padding:10px;">🗑 삭제</button>
    </div>
  </div>
</div>

<!-- 편지 수정 모달 -->
<div class="modal-bg" id="editModal" onclick="closeEditModal(event)">
  <div class="write-modal">
    <h3>✏️ 편지 수정</h3>
    <div class="form-group">
      <label class="form-label">봉투 이모지</label>
      <div class="emoji-row" id="editEmojiRow"></div>
    </div>
    <div class="form-group">
      <label class="form-label">축하 메시지</label>
      <textarea class="form-textarea" id="editMsg"></textarea>
    </div>
    <div class="form-btns">
      <button class="btn-cancel" onclick="closeEditModal()">취소</button>
      <button class="btn-submit" id="editBtn" onclick="submitEdit()">수정 완료</button>
    </div>
  </div>
</div>

<!-- 쓰기 모달 -->
<div class="modal-bg" id="writeModal" onclick="closeWriteModal(event)">
  <div class="write-modal">
    <h3>✉ 감사 편지 쓰기</h3>
    <div class="form-group">
      <label class="form-label">보내는 분</label>
      <input class="form-input" type="text" id="writerName" placeholder="이름 또는 닉네임" maxlength="20"/>
    </div>
    <div class="form-group">
      <label class="form-label">비밀번호 (4자리) — 내 편지를 나중에 확인할 때 사용해요</label>
      <input class="form-input" type="password" id="writerPw" placeholder="숫자 또는 문자 4자리" maxlength="4" style="letter-spacing:0.3em;font-size:18px;"/>
    </div>
    <div class="form-group">
      <label class="form-label">봉투 이모지</label>
      <div class="emoji-row" id="emojiRow"></div>
    </div>
    <div class="form-group">
      <label class="form-label">축하 메시지</label>
      <textarea class="form-textarea" id="writerMsg" placeholder="스승님께 감사한 마음을 담아 편지를 써주세요 :)"></textarea>
    </div>
    <div class="form-btns">
      <button class="btn-cancel" onclick="closeWriteModal()">취소</button>
      <button class="btn-submit" id="submitBtn" onclick="submitLetter()">편지 보내기 💌</button>
    </div>
  </div>
</div>

<!-- 내 편지 확인 모달 -->
<div class="modal-bg" id="myLetterModal" onclick="closeMyLetterModal(event)">
  <div class="write-modal">
    <h3>🔐 내 편지 확인</h3>
    <div class="form-group">
      <label class="form-label">이름</label>
      <input class="form-input" type="text" id="checkName" placeholder="편지 작성 시 입력한 이름" maxlength="20"/>
    </div>
    <div class="form-group">
      <label class="form-label">비밀번호 (4자리)</label>
      <input class="form-input" type="password" id="checkPw" placeholder="설정한 비밀번호 4자리" maxlength="4" style="letter-spacing:0.3em;font-size:18px;"/>
    </div>
    <div class="form-btns">
      <button class="btn-cancel" onclick="closeMyLetterModal()">취소</button>
      <button class="btn-submit" onclick="checkMyLetter()">확인하기</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<!-- Firebase -->
<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getFirestore, doc, getDoc, setDoc, collection, addDoc, getDocs, deleteDoc, orderBy, query } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";

const firebaseConfig = {
  apiKey: "AIzaSyDDyRxHF4-7vmRwuBdZVgIl5D7wXDa7Qag",
  authDomain: "happy-birthday-ch.firebaseapp.com",
  projectId: "happy-birthday-ch",
  storageBucket: "happy-birthday-ch.firebasestorage.app",
  messagingSenderId: "466279772788",
  appId: "1:466279772788:web:bd0fd6ec0daba4aa9fd721"
};

const app = initializeApp(firebaseConfig);
const db = getFirestore(app);

const EMOJIS = ['🌸','🎂','🎁','💐','🌹','✨','🎉','🥂','💛','🌻','🍀','🦋'];
const params = new URLSearchParams(location.search);
const MODE = params.get('mode') === 'admin' ? 'admin' : params.get('mode') === 'write' ? 'write' : 'guest';
const BASE_URL = location.origin + location.pathname;

let selectedEmoji = EMOJIS[0];
let letters = [];
let profile = { name:'본부장님', msg:'스승의 날을 맞아\n언제나 가르침을 주시는 본부장님께\n진심 어린 감사의 마음을 전합니다.', date: new Date().toISOString().slice(0,10), photo: null };

async function loadProfile() {
  const snap = await getDoc(doc(db, 'teacher', 'profile'));
  if (snap.exists()) profile = { ...profile, ...snap.data() };
}

async function saveProfile() {
  await setDoc(doc(db, 'teacher', 'profile'), profile);
}

async function loadLetters() {
  const q = query(collection(db, 'letters_teacher'), orderBy('createdAt', 'desc'));
  const snap = await getDocs(q);
  letters = snap.docs.map(d => ({ id: d.id, ...d.data() }));
}

async function addLetter(letter) {
  await addDoc(collection(db, 'letters_teacher'), { ...letter, createdAt: Date.now() });
}

async function deleteLetter(id) {
  await deleteDoc(doc(db, 'letters_teacher', id));
}

async function init() {
  await Promise.all([loadProfile(), loadLetters()]);
  render();
  if (params.get('mode') === 'write') setTimeout(openWriteModal, 500);
}

function render() {
  const app = document.getElementById('app');
  app.innerHTML = '';
  if (MODE === 'admin') renderAdminBar(app);
  renderHero(app);
  if (MODE === 'write') {
    renderWriteOnly(app);
  } else {
    renderLetters(app);
  }
  if (MODE === 'write') {
    const fab = document.createElement('button');
    fab.className = 'write-fab';
    fab.innerHTML = '✉ 감사 편지 쓰기';
    fab.onclick = openWriteModal;
    app.appendChild(fab);
  }
}

function renderWriteOnly(app) {
  const section = document.createElement('div');
  section.className = 'letters-section';

  let envelopes = '';
  if (!letters.length) {
    envelopes = `<div class="empty-letters">💌<p>아직 편지가 없어요.<br>첫 번째 감사 편지를 보내주세요!</p></div>`;
  } else {
    envelopes = letters.map(l => `
      <div class="envelope-wrap">
        <div class="envelope" style="cursor:default;">
          <div class="envelope-body">
            <div class="envelope-corner"></div>
            <div class="envelope-petals">🌹 ✨ 🌹</div>
            <div class="envelope-seal">${l.emoji||'💌'}</div>
            <div class="envelope-from">${l.from}</div>
            <div class="envelope-locked">✉ 내용은 비공개예요</div>
          </div>
          <div class="envelope-flap"></div>
        </div>
      </div>
    `).join('');
  }

  section.innerHTML = `
    <div class="letters-title">✦ 축하 편지 ${letters.length}통 ✦</div>
    <div class="letters-grid">${envelopes}</div>
    <div style="text-align:center;margin-top:32px;">
      <button onclick="openMyLetterModal()" style="background:transparent;border:1px solid var(--border);border-radius:6px;color:var(--text2);cursor:pointer;font-family:'Noto Sans KR',sans-serif;font-size:13px;padding:10px 20px;">🔐 내가 쓴 편지 확인</button>
    </div>
  `;
  app.appendChild(section);
}

function renderAdminBar(app) {
  const bar = document.createElement('div');
  bar.className = 'admin-bar';
  bar.innerHTML = `
    <div style="display:flex;align-items:center;">
      <span class="admin-badge">관리자</span>생일 롤링페이퍼
    </div>
    <div class="admin-btns">
      <button class="admin-btn" onclick="toggleSettings()">⚙ 설정</button>
      <button class="admin-btn" onclick="copyLink('guest')">🔗 생일자 링크</button>
      <button class="admin-btn" onclick="copyLink('write')">✉ 편지쓰기 링크</button>
    </div>
  `;
  app.appendChild(bar);

  const settings = document.createElement('div');
  settings.className = 'settings-panel';
  settings.id = 'settingsPanel';
  settings.innerHTML = `
    <div class="settings-grid">
      <div class="settings-group">
        <label class="settings-label">생일자 이름</label>
        <input class="settings-input" id="setName" value="${profile.name}" />
      </div>
      <div class="settings-group">
        <label class="settings-label">생일 날짜</label>
        <input class="settings-input" id="setDate" type="date" value="${profile.date}" />
      </div>
      <div class="settings-group" style="grid-column:1/-1;">
        <label class="settings-label">대표 축하문구</label>
        <textarea class="settings-input" id="setMsg" rows="3" style="resize:vertical;">${profile.msg}</textarea>
      </div>
      <div class="settings-group">
        <label class="settings-label">생일자 사진</label>
        <input type="file" id="setPhotoFile" accept="image/*" style="font-size:13px;padding:4px 0;" onchange="previewPhoto(this)" />
        <div id="photoStatus" style="font-size:11px;color:var(--text3);margin-top:4px;">${profile.photo ? '사진 등록됨 ✓' : '사진 없음'}</div>
      </div>
    </div>
    <button class="settings-save" onclick="saveSettings()">저장하기</button>
  `;
  app.appendChild(settings);

  const linkBox = document.createElement('div');
  linkBox.className = 'link-box';
  linkBox.innerHTML = `
    <div class="link-box-title">공유 링크</div>
    <div class="link-row">
      <span class="link-label">생일자용</span>
      <span class="link-url">${BASE_URL}</span>
      <button class="link-copy" onclick="copyLink('guest')">복사</button>
    </div>
    <div class="link-row">
      <span class="link-label">편지쓰기</span>
      <span class="link-url">${BASE_URL}?mode=write</span>
      <button class="link-copy" onclick="copyLink('write')">복사</button>
    </div>
    <div class="link-row">
      <span class="link-label">관리자</span>
      <span class="link-url">${BASE_URL}?mode=admin</span>
      <button class="link-copy" onclick="copyLink('admin')">복사</button>
    </div>
  `;
  app.appendChild(linkBox);
}

function renderHero(app) {
  const hero = document.createElement('div');
  hero.className = 'hero';
  hero.innerHTML = `
    <div class="hero-flowers">🌹 🎓 🌹 🎓 🌹</div>
    <div class="photo-wrap">
      <div class="photo-ring"></div>
      <div class="photo-frame">
        ${profile.photo
          ? `<img src="${profile.photo}" alt="생일자 사진" />`
          : `<div class="photo-placeholder"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="36" height="36"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>${MODE==='admin'?'사진 추가':''}</div>`}
      </div>
    </div>
    <div class="hero-name">${profile.name}</div>
    <div class="hero-msg">${profile.msg.replace(/\n/g,'<br>')}</div>
    <div class="hero-date">🎓 스승의 날 · ${profile.date}</div>
    <div class="divider">✦</div>
  `;
  app.appendChild(hero);
}

function renderLetters(app) {
  const section = document.createElement('div');
  section.className = 'letters-section';
  section.innerHTML = `<div class="letters-title">✦ 축하 편지 ${letters.length}통 ✦</div>`;
  const grid = document.createElement('div');
  grid.className = 'letters-grid';

  if (!letters.length) {
    grid.innerHTML = `<div class="empty-letters">💌<p>아직 편지가 없어요.<br>첫 번째 감사 편지를 보내주세요!</p></div>`;
  } else {
    letters.forEach((letter, i) => {
      const wrap = document.createElement('div');
      wrap.className = 'envelope-wrap';
      wrap.innerHTML = `
        ${MODE==='admin' ? `<button class="delete-btn" onclick="handleDelete('${letter.id}')">삭제</button>` : ''}
        <div class="envelope" onclick="openLetter(${i})">
          <div class="envelope-body">
            <div class="envelope-corner"></div>
            <div class="envelope-petals">🌹 ✨ 🌹</div>
            <div class="envelope-seal">${letter.emoji||'💌'}</div>
            <div class="envelope-from">${letter.from}</div>
            <div class="envelope-locked">✉ 열어보세요</div>
          </div>
          <div class="envelope-flap"></div>
        </div>
      `;
      grid.appendChild(wrap);
    });
  }
  section.appendChild(grid);
  app.appendChild(section);
}

window.toggleSettings = () => document.getElementById('settingsPanel')?.classList.toggle('open');

window.previewPhoto = (input) => {
  const file = input.files[0];
  if (!file) return;
  const status = document.getElementById('photoStatus');
  if (file.size > 1024 * 1024) {
    if (status) status.textContent = '⚠ 1MB 이하 이미지를 사용해주세요';
    input.value = '';
    return;
  }
  if (status) status.textContent = `${file.name} 선택됨`;
};

window.saveSettings = async () => {
  profile.name = document.getElementById('setName').value.trim() || profile.name;
  profile.date = document.getElementById('setDate').value || profile.date;
  profile.msg = document.getElementById('setMsg').value.trim() || profile.msg;

  const fileInput = document.getElementById('setPhotoFile');
  const file = fileInput?.files[0];

  if (file) {
    const reader = new FileReader();
    reader.onload = async (e) => {
      profile.photo = e.target.result;
      await saveProfile();
      render();
      showToast('저장됐어요!');
    };
    reader.readAsDataURL(file);
  } else {
    await saveProfile();
    render();
    showToast('저장됐어요!');
  }
};

window.closeReadModal = (e) => {
  if (!e || e.target===document.getElementById('readModal'))
    document.getElementById('readModal').classList.remove('open');
};

window.openWriteModal = () => {
  document.getElementById('emojiRow').innerHTML = EMOJIS.map(e =>
    `<button class="emoji-btn ${e===selectedEmoji?'selected':''}" onclick="selectEmoji('${e}',this)">${e}</button>`
  ).join('');
  document.getElementById('writeModal').classList.add('open');
};

window.closeWriteModal = (e) => {
  if (!e || e.target===document.getElementById('writeModal'))
    document.getElementById('writeModal').classList.remove('open');
};

window.selectEmoji = (emoji, btn) => {
  selectedEmoji = emoji;
  document.querySelectorAll('.emoji-btn').forEach(b=>b.classList.remove('selected'));
  btn.classList.add('selected');
};

window.submitLetter = async () => {
  const from = document.getElementById('writerName').value.trim();
  const pw = document.getElementById('writerPw').value.trim();
  const msg = document.getElementById('writerMsg').value.trim();
  if (!from) { showToast('이름을 입력해주세요'); return; }
  if (pw.length !== 4) { showToast('비밀번호는 4자리로 입력해주세요'); return; }
  if (!msg) { showToast('메시지를 입력해주세요'); return; }
  const btn = document.getElementById('submitBtn');
  btn.disabled = true; btn.textContent = '전송 중...';
  await addLetter({ from, msg, emoji: selectedEmoji, pw });
  await loadLetters();
  closeWriteModal();
  document.getElementById('writerName').value = '';
  document.getElementById('writerPw').value = '';
  document.getElementById('writerMsg').value = '';
  btn.disabled = false; btn.textContent = '편지 보내기 💌';
  render();
  showToast('편지가 전달됐어요 💌');
};

window.openMyLetterModal = () => {
  document.getElementById('myLetterModal').classList.add('open');
};

window.closeMyLetterModal = (e) => {
  if (!e || e.target===document.getElementById('myLetterModal'))
    document.getElementById('myLetterModal').classList.remove('open');
};

let myLetterId = null;
let myLetterEmoji = EMOJIS[0];

window.checkMyLetter = () => {
  const name = document.getElementById('checkName').value.trim();
  const pw = document.getElementById('checkPw').value.trim();
  if (!name || pw.length !== 4) { showToast('이름과 4자리 비밀번호를 입력해주세요'); return; }
  const found = letters.find(l => l.from === name && l.pw === pw);
  if (!found) { showToast('일치하는 편지가 없어요'); return; }
  myLetterId = found.id;
  myLetterEmoji = found.emoji || EMOJIS[0];
  closeMyLetterModal();
  const i = letters.indexOf(found);
  openLetter(i, true);
};

window.openLetter = (i, isOwner = false) => {
  const l = letters[i];
  document.getElementById('modalEmoji').textContent = l.emoji||'💌';
  document.getElementById('modalFrom').textContent = l.from;
  document.getElementById('modalFlowers').textContent = '🌹 🎓 🌹';
  document.getElementById('modalBody').textContent = l.msg;
  document.getElementById('modalDate').textContent = new Date(l.createdAt).toLocaleDateString('ko-KR',{year:'numeric',month:'long',day:'numeric'});
  const btns = document.getElementById('myLetterBtns');
  if (isOwner || MODE === 'admin') {
    btns.style.display = 'flex';
    if (!isOwner && MODE === 'admin') myLetterId = l.id;
  } else {
    btns.style.display = 'none';
  }
  document.getElementById('readModal').classList.add('open');
};

window.openEditModal = () => {
  const letter = letters.find(l => l.id === myLetterId);
  if (!letter) return;
  myLetterEmoji = letter.emoji || EMOJIS[0];
  document.getElementById('editEmojiRow').innerHTML = EMOJIS.map(e =>
    `<button class="emoji-btn ${e===myLetterEmoji?'selected':''}" onclick="selectEditEmoji('${e}',this)">${e}</button>`
  ).join('');
  document.getElementById('editMsg').value = letter.msg;
  document.getElementById('readModal').classList.remove('open');
  document.getElementById('editModal').classList.add('open');
};

window.closeEditModal = (e) => {
  if (!e || e.target===document.getElementById('editModal'))
    document.getElementById('editModal').classList.remove('open');
};

window.selectEditEmoji = (emoji, btn) => {
  myLetterEmoji = emoji;
  document.querySelectorAll('#editEmojiRow .emoji-btn').forEach(b=>b.classList.remove('selected'));
  btn.classList.add('selected');
};

window.submitEdit = async () => {
  const msg = document.getElementById('editMsg').value.trim();
  if (!msg) { showToast('메시지를 입력해주세요'); return; }
  const btn = document.getElementById('editBtn');
  btn.disabled = true; btn.textContent = '수정 중...';
  const letter = letters.find(l => l.id === myLetterId);
  await setDoc(doc(db, 'letters_teacher', myLetterId), { ...letter, msg, emoji: myLetterEmoji });
  await loadLetters();
  closeEditModal();
  btn.disabled = false; btn.textContent = '수정 완료';
  render();
  showToast('편지가 수정됐어요!');
};

window.deleteMyLetter = async () => {
  if (!confirm('편지를 삭제할까요?')) return;
  await deleteLetter(myLetterId);
  await loadLetters();
  document.getElementById('readModal').classList.remove('open');
  myLetterId = null;
  render();
  showToast('편지가 삭제됐어요');
};

window.handleDelete = async (id) => {
  if (!confirm('이 편지를 삭제할까요?')) return;
  await deleteLetter(id);
  await loadLetters();
  render();
  showToast('삭제됐어요');
};

window.copyLink = (type) => {
  let url = BASE_URL;
  if (type === 'write') url += '?mode=write';
  if (type === 'admin') url += '?mode=admin';
  navigator.clipboard.writeText(url).then(() => showToast('링크가 복사됐어요!'));
};

window.showToast = (msg) => {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
};

init();
</script>
</body>
</html>
